{
  "governance_version": "0.1.0",
  "agent_id": "mobius.science.synthesis",
  "title": "Science Synthesis Chamber Governance Rules",
  "purpose": "Define high-stakes review and publication controls for scientific synthesis outputs.",
  "review_lanes": {
    "default_owner": "zenith",
    "secondary_reviewers": [
      "atlas",
      "eve",
      "jade"
    ],
    "required_for_high_stakes": [
      "eve",
      "atlas"
    ]
  },
  "high_stakes_triggers": [
    {
      "id": "medical_inference",
      "label": "Medical advice could be inferred",
      "required_review": [
        "eve",
        "atlas"
      ],
      "publication_gate": "hold_until_approved"
    },
    {
      "id": "biosecurity_sensitive",
      "label": "Biosecurity-sensitive content",
      "required_review": [
        "eve",
        "atlas"
      ],
      "publication_gate": "restricted"
    },
    {
      "id": "population_genetics",
      "label": "Genetic identity or ancestry claims affecting populations",
      "required_review": [
        "eve",
        "atlas",
        "jade"
      ],
      "publication_gate": "hold_until_approved"
    },
    {
      "id": "public_fear_risk",
      "label": "Findings may materially affect public fear or health behavior",
      "required_review": [
        "eve"
      ],
      "publication_gate": "tone_check_required"
    },
    {
      "id": "narrow_evidence_policy",
      "label": "Policy recommendation drawn from narrow evidence",
      "required_review": [
        "eve",
        "atlas"
      ],
      "publication_gate": "attach_policy_caution"
    }
  ],
  "frontier_vs_consensus_rules": {
    "frontier": {
      "required_labels": [
        "frontier",
        "low_or_moderate_confidence",
        "replication_pending"
      ],
      "must_include": [
        "what_is_unproven",
        "replication_requirements",
        "uncertainty_note"
      ],
      "must_not_include": [
        "settled_language",
        "deterministic_policy_recommendation"
      ]
    },
    "consensus": {
      "required_labels": [
        "consensus",
        "confidence_stated",
        "source_lineage_complete"
      ],
      "must_include": [
        "stability_statement",
        "remaining_uncertainties",
        "review_reopen_conditions"
      ]
    }
  },
  "jade_deferral_rules": {
    "jade_must_defer_when": [
      "method_class_missing",
      "confidence_unassigned",
      "consensus_state_missing_and_not_marked_unknown",
      "high_stakes_trigger_active"
    ],
    "defer_to": [
      "eve",
      "atlas",
      "zenith"
    ],
    "note": "Jade may translate only after scientific structure and governance checks are satisfied."
  },
  "archive_mutation_rules": {
    "allowed_mutations": [
      "append_delta_entry",
      "update_confidence_with_trace",
      "add_new_sources",
      "reclassify_consensus_state_with_change_log"
    ],
    "forbidden_mutations": [
      "silent_overwrite_of_disputed_records",
      "deletion_of_uncertainty_notes",
      "retroactive_consensus_without_evidence"
    ],
    "requirements": [
      "all mutations must include actor, timestamp, rationale",
      "previous state must remain recoverable",
      "major changes require atlas review"
    ]
  },
  "publication_controls": {
    "minimum_required_fields": [
      "finding",
      "method_class",
      "confidence",
      "consensus_state",
      "what_data_shows",
      "what_data_does_not_show",
      "provenance"
    ],
    "hard_blocks": [
      "missing_provenance",
      "missing_confidence",
      "missing_method_class"
    ]
  }
}
