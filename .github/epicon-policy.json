{
  "$comment": "EPICON tier policy for mobius-civic-ai-terminal. Declarative, proposer-independent (Rule 5.1). Unmatched paths classify EP-3 (Rule 5.2). PR tier = max across changed files (Rule 5.3).",
  "policy_id": "terminal-policy-v1",
  "EP-1": [
    "docs/**",
    "**/*.md",
    "*.md",
    "public/**",
    "journal/**"
  ],
  "EP-2": [
    "app/**",
    "api/**",
    "components/**",
    "pages/**",
    "hooks/**",
    "contexts/**",
    "packages/**",
    "sdk/**",
    "scripts/**",
    "types/**",
    "data/**",
    "tests/**",
    "lib/**",
    "mesh/**",
    "ledger/**",
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "tailwind.config.ts",
    "postcss.config.js",
    "next.config.ts"
  ],
  "EP-3": [
    "docs/epicon/**",
    "auth.ts",
    "gateway.py",
    "agents/**",
    ".github/workflows/**",
    "CODEOWNERS",
    "render.yaml",
    "vercel.json",
    "mobius.yaml",
    "MOBIUS_TRUST_TRIPWIRES_V1.md"
  ]
}
