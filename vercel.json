{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "ignoreCommand": "bash scripts/ignore-build.sh",
  "crons": [
    {
      "path": "/api/cron/heartbeat",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/promote",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/vault-attestation",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/sweep",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/swarm",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/reserve-canon-append",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/reserve-canon-integrity",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/journal-canonize",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/publish-oaa-snapshots",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/reattest-seals",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/echo-ingest",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/cron/gi-refresh",
      "schedule": "45 1 * * *"
    },
    {
      "path": "/api/eve/cycle-synthesize",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/kv-watchdog",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/watchdog",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/vault/block/attest-sweep",
      "schedule": "0 */6 * * *"
    }
  ],
  "installCommand": "pnpm install --frozen-lockfile"
}
