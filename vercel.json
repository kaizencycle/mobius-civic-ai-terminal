{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "ignoreCommand": "bash scripts/ignore-build.sh",
  "crons": [
    {
      "path": "/api/cron/watchdog",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/eve/cycle-synthesize",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/promote",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/promote",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/gi-refresh",
      "schedule": "45 0 * * *"
    },
    {
      "path": "/api/cron/vault-attestation",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/heartbeat",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sweep",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/publish-oaa-snapshots",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/echo-ingest",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/vault/block/attest-sweep",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/reattest-seals",
      "schedule": "0 * * * *"
    }
  ],
  "installCommand": "pnpm install --no-frozen-lockfile"
}
