{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "ignoreCommand": "git log -1 --format='%s' | grep -q '\\[skip ci\\]'",
  "crons": [
    {
      "path": "/api/eve/cycle-advance",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/echo/ingest",
      "schedule": "5 5 * * *"
    },
    {
      "path": "/api/signals/micro",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/integrity-status",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/aurea/oversee",
      "schedule": "35 5 * * *"
    },
    {
      "path": "/api/runtime/heartbeat",
      "schedule": "*/30 * * * *"
    }
  ]
}
